JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token
# Or use OAuth instead of basic auth:
# JIRA_ACCESS_TOKEN=your-access-token

# Webhook listener port. Defaults to 6543.
JIRA_WEBHOOK_PORT=6543

# Webhook listener bind host. Defaults to 127.0.0.1.
# Set to 0.0.0.0 if Jira must reach this server from another machine.
# JIRA_WEBHOOK_HOST=127.0.0.1

# Optional: verifies Jira admin webhooks signed with X-Hub-Signature.
# JIRA_WEBHOOK_SECRET=your-webhook-secret
